{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Meeting AI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-create",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-document-recursive",
    "fs:scope-temp-recursive",
    "fs:scope-appcache-recursive",
    "fs:scope-appdata-recursive",
    "fs:allow-stat"
  ]
}
